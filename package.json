{
  "name": "capmonster",
  "version": "1.0.0",
  "description": "Lightweight desktop app to preview and record video/audio from capture cards (Elgato, AverMedia, HDMI grabbers, etc.)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.capmonster.app",
    "productName": "CapMonster",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "icon": "assets/icon.png",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmartinezluxury/capmonster.git"
  },
  "author": "Josue Martinez",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "dependencies": {
    "vue": "^3.5.32"
  }
}
